# ─── WhatsApp Cloud API Credentials ───────────────────────────────────────────
# From Meta Developer Console → Your App → WhatsApp → API Setup

# A random string YOU choose — used to verify the webhook handshake with Meta
WHATSAPP_VERIFY_TOKEN=trai_webhook_secret_2024

# Permanent System User Token (from Meta → Business Settings → System Users)
# Or the temporary token shown in API Setup (expires in 24h, good for testing)
WHATSAPP_API_TOKEN=your_token_here

# Phone Number ID — shown in Meta API Setup (e.g. 173000262573577)
WHATSAPP_PHONE_NUMBER_ID=173000262573577

# YOUR personal WhatsApp number with country code, no + or spaces
YOUR_WHATSAPP_NUMBER=917905495478

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
